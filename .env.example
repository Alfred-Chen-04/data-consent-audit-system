# Copy this file to .env and fill in real values. NEVER commit .env.

# --- LLM / VLM providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Which models to use (override-able for cheaper experiments)
ANTHROPIC_VLM_MODEL=claude-opus-4-7
ANTHROPIC_LLM_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_LLM_DEEP_MODEL=claude-opus-4-7
OPENAI_VLM_MODEL=gpt-4o

# --- Storage ---
# PostgreSQL connection URL (Supabase, Neon, or local)
DATABASE_URL=postgresql://user:pass@localhost:5432/consent_audit

# S3-compatible object storage for screenshots / DOM snapshots
S3_ENDPOINT_URL=https://...r2.cloudflarestorage.com
S3_BUCKET=consent-audit-captures
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Runtime limits ---
# Hard cap on cumulative API spend per weekly run (USD). Pipeline aborts if exceeded.
SSRP_BUDGET_CAP=50.00

# Browser agent per-site time budget (seconds)
AGENT_SITE_TIMEOUT=180

# --- Observability ---
LOG_LEVEL=INFO
